# Site URL used for canonical links, Open Graph tags, and sitemap generation.
VITE_SITE_URL=https://agricones.com

# SMTP settings for the contact form email delivery.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=info@agricones.com
SMTP_PASS=your-smtp-password
SMTP_SECURE=false

# Optional overrides for outgoing and destination email addresses.
CONTACT_FROM_EMAIL=info@agricones.com
CONTACT_TO_EMAIL=info@agricones.com
